# ==========================================
# ModularAuth Environment Configuration
# ==========================================
# Copy this file to '.env.dev' (or '.env') and fill in your values.
# Do NOT commit the actual .env file to version control.

# --- .NET API Settings ---
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# --- Database Credentials (MySQL) ---
# The root password for the MySQL instance.
MYSQL_ROOT_PASSWORD=your_secure_root_password

# The name of the database to create automatically.
MYSQL_DATABASE=ModularAuthDB

# The username for the application to connect with.
MYSQL_USER=modularauth_user

# The password for the application user. 
# CHANGE THIS TO A SECURE PASSWORD.
MYSQL_PASSWORD=your_secure_user_password

# --- Docker Connection String ---
# This is used by the API container to connect to the DB container.
# Note: 'Server' must match the service name in docker-compose.yml (e.g., modularauth-db).
# Note: 'AllowPublicKeyRetrieval=True' is required for MySQL 8.0+.
DB_CONNECTION_STRING=Server=modularauth-db;Port=3306;Database=ModularAuthDB;User=modularauth_user;Password=your_secure_user_password;GuidFormat=Char36;AllowPublicKeyRetrieval=True;